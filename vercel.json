{
  "version": 2,
  "buildCommand": "pnpm run build",
  "outputDirectory": "dist/public",
  "rewrites": [
    { "source": "/api/:path*", "destination": "https://blox-project-api.onrender.com/api/:path*" },
    { "source": "/uploads/:path*", "destination": "https://blox-project-api.onrender.com/uploads/:path*" },
    { "source": "/:path*", "destination": "/index.html" }
  ]
}
